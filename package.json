{  "name": "local-flow-ide",  "private": true,  "version": "0.1.0",  "type": "module",  "description": "Local-first AI development environment",  "scripts": {    "dev": "pnpm --filter @local-flow/desktop dev",    "build": "pnpm --filter @local-flow/desktop build",    "build:packages": "pnpm --filter './packages/**' build",    "lint": "eslint . --ext .ts,.tsx",    "format": "prettier --write '**/*.{ts,tsx,json,css,md}'",    "test": "pnpm --filter @local-flow/desktop test",    "test:rust": "cd src-tauri && cargo test",    "typecheck": "pnpm --filter @local-flow/desktop typecheck",    "clean": "pnpm -r exec -- rm -rf dist node_modules .turbo"  },  "engines": {    "node": ">=18",    "pnpm": ">=8"  },  "devDependencies": {    "@typescript-eslint/eslint-plugin": "^7.0.0",    "@typescript-eslint/parser": "^7.0.0",    "eslint": "^8.57.0",    "prettier": "^3.2.0",    "typescript": "^5.4.0",    "vitest": "^1.6.0"  }}