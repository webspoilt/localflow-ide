{
  "name": "zynta-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Local-first AI development environment",
  "scripts": {
    "dev": "pnpm --filter @zynta/desktop dev",
    "build": "pnpm --filter @zynta/desktop build",
    "build:packages": "pnpm --filter './packages/**' build",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write '**/*.{ts,tsx,json,css,md}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rust": "cd src-tauri && cargo test",
    "typecheck": "tsc --noEmit",
    "clean": "pnpm -r exec -- rm -rf dist node_modules .turbo"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
