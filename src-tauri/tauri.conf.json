{
    "productName": "Zynta Studio",
    "version": "0.1.0",
    "identifier": "com.zyntastudio.dev",
    "build": {
        "beforeDevCommand": "pnpm --filter @zynta/desktop dev",
        "beforeBuildCommand": "pnpm --filter @zynta/desktop build",
        "frontendDist": "../apps/desktop/dist",
        "devUrl": "http://localhost:1420"
    },
    "app": {
        "windows": [
            {
                "title": "Zynta Studio",
                "width": 1440,
                "height": 1024,
                "minWidth": 800,
                "minHeight": 600,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": "default-src 'self'; connect-src 'self' http://localhost:1420"
        }
    },
    "bundle": {
        "active": true,
        "category": "DeveloperTool",
        "targets": "all",
        "windows": {
            "webviewInstallMode": {
                "type": "offlineInstaller"
            }
        },
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
